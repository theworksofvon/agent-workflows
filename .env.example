# GitHub auth — PAT with repo + PR comments read/write
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Repos to watch in daemon mode, comma-separated.
# Manual review mode can target any PR your token can access.
REPOS=owner/repo,owner/repo2

# How often to poll for new comments (seconds)
POLL_INTERVAL_SEC=60

# Wait this long after the latest comment in a group before running the agent
COMMENT_BATCH_WINDOW_SEC=120

# Context and state retention limits
PR_CONTEXT_HISTORY_LIMIT=5
COMMENT_BATCH_HISTORY_LIMIT=20
PROCESSED_COMMENT_KEY_LIMIT=2000

# Retry retryable agent failures such as rate/usage limits
AGENT_RETRY_DELAY_SEC=1800
AGENT_MAX_ATTEMPTS=5

# Which coding agent adapter to use (zcode | claude-code | codex)
AGENT=codex

# Second independent review pass: off | auto | always.
# auto runs only for large/sensitive diffs or high-severity primary findings.
REVIEW_ADVERSARIAL_MODE=auto

# Adapter for the second pass. Defaults to AGENT; use a different provider for
# stronger independence when available.
REVIEW_ADVERSARIAL_AGENT=

# A new state directory skips comments that already exist on its first poll.
# Set true only when you intentionally want to process existing comments.
PROCESS_EXISTING_COMMENTS_ON_FIRST_RUN=false

# Username of this daemon's own GitHub account, so it ignores its own comments
# and doesn't trigger itself in a loop. Optional.
#
# Leave unset for personal-token mode (daemon and you share one account): the
# daemon then relies solely on the marker tag (<!-- agent-workflows:bot -->) it
# stamps on its own comments, so your own comments still trigger it.
#
# Set it to a dedicated bot account's username to also ignore every comment from
# that account, regardless of the marker.
AGENT_SELF_USER=your-bot-name

# Directory for repo state files + per-task workdirs (gitignored)
STATE_DIR=./state

# --- agent-specific passthrough (used by the matching adapter) ---

# ZCode adapter
ZCODE_BIN=zcode

# Claude Code adapter
CLAUDE_CODE_BIN=claude

# Codex adapter
CODEX_BIN=codex

# Keep per-task workdirs after completion for debugging (true | false)
KEEP_WORKDIRS=false
